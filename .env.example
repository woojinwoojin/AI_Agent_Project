# 이 파일을 복사해서 .env 로 만들고 값을 채우세요:  cp .env.example .env
# .env 는 절대 커밋하지 마세요 (.gitignore 처리됨)

ENVIRONMENT=development
DEBUG=true

# Upstage (Solar) — https://console.upstage.ai 에서 발급
UPSTAGE_API_KEY=your-upstage-api-key
LLM_MODEL=solar-pro3

# PostgreSQL + pgvector (docker-compose 기본값과 일치)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gachon_ai
