# 이 파일을 복사해서 .env 로 만들고 값을 채우세요:  cp .env.example .env
# .env 는 절대 커밋하지 마세요 (.gitignore 처리됨)

ENVIRONMENT=development
DEBUG=true

# Upstage (Solar) — https://console.upstage.ai 에서 발급
UPSTAGE_API_KEY=your-upstage-api-key
LLM_MODEL=solar-pro3

# PostgreSQL + pgvector (docker-compose 기본값과 일치)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gachon_ai

# Langfuse 관측성 (LangGraph trace)
# key는 region 전용이다. 본 프로젝트는 Japan region(jp.cloud.langfuse.com) 사용.
# 로컬에선 ENABLED=false로 꺼두고, key를 채운 뒤 true로 바꿔 사용.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com
LANGFUSE_ENV=local
